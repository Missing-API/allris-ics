{
  "name": "allris-ics",
  "version": "1.5.0",
  "description": "A middleware service that enhances ICS calendar feeds from Allris meeting management software by fetching detailed meeting information and formatting it for better readability.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Missing-API/allris-ics"
  },
  "bugs": {
    "url": "https://github.com/Missing-API/allris-ics/issues"
  },
  "homepage": "https://github.com/Missing-API/allris-ics#readme",
  "author": "Jan-Henrik Hempel <jan@schafe-vorm-fenster.de>",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "next dev -p 3050",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --maxWorkers=25% --testPathIgnorePatterns='.*\\.integration\\.ts$'",
    "test:watch": "jest --watch --maxWorkers=25% --testPathIgnorePatterns='.*\\.integration\\.ts$'",
    "test:ci": "jest --runInBand --testPathIgnorePatterns='.*\\.integration\\.ts$'",
    "test:integration": "jest --maxWorkers=25% --testMatch='**/*.integration.ts' --testTimeout=120000",
    "test:all": "jest --maxWorkers=25%",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=22.x"
  },
  "dependencies": {
    "@schafevormfenster/data-text-mapper": "^0.2.2",
    "@sparticuz/chromium": "^143.0.0",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "iconv": "^3.0.1",
    "ics": "https://github.com/schafevormfenster/ics.git",
    "js-yaml": "^4.1.1",
    "next": "^13.5.11",
    "next-swagger-doc": "^0.3.6",
    "next-transpile-modules": "^10.0.1",
    "node-ical": "^0.15.3",
    "playwright-core": "^1.57.0",
    "re2": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "slugify": "^1.6.6",
    "swagger-ui-react": "^4.15.2",
    "url-regex-safe": "^3.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.3",
    "@types/react": "18.0.18",
    "@types/react-dom": "18.0.6",
    "@types/swagger-ui-react": "^4.19.0",
    "eslint": "8.23.0",
    "eslint-config-next": "13.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^28.0.8",
    "typescript": "4.8.2"
  }
}
